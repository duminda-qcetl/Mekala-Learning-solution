# ================================
# Mekala Platform Configuration
# ================================

# Environment
NODE_ENV=development
RUST_ENV=development

# Database Configuration
DATABASE_URL=postgresql://mekala_user:mekala_pass@postgres:5432/mekala_db
POSTGRES_USER=mekala_user
POSTGRES_PASSWORD=mekala_pass
POSTGRES_DB=mekala_db

# Redis Configuration
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# RabbitMQ Configuration
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=86400

# API Gateway
API_GATEWAY_PORT=8000
API_GATEWAY_HOST=0.0.0.0

# Service Ports
USER_SERVICE_PORT=8001
PAYMENT_SERVICE_PORT=8002
COURSE_SERVICE_PORT=8003
AI_SERVICE_PORT=8004
COMMUNICATION_SERVICE_PORT=8005

# Service URLs (Internal)
USER_SERVICE_URL=http://user-service:8001
PAYMENT_SERVICE_URL=http://payment-service:8002
COURSE_SERVICE_URL=http://course-service:8003
AI_SERVICE_URL=http://ai-service:8004
COMMUNICATION_SERVICE_URL=http://communication-service:8005

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8000
REACT_APP_WS_URL=ws://localhost:8000/ws
FRONTEND_PORT=3000

# Payment Gateways
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_SECRET=your_paypal_secret
PAYHERE_MERCHANT_ID=your_payhere_merchant_id
PAYHERE_SECRET=your_payhere_secret
XENDIT_API_KEY=your_xendit_api_key

# Communication Services
WHATSAPP_API_TOKEN=your_whatsapp_business_api_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@mekala.edu

# Video Conferencing
ZOOM_API_KEY=your_zoom_api_key
ZOOM_API_SECRET=your_zoom_api_secret
TEAMS_CLIENT_ID=your_teams_client_id
TEAMS_CLIENT_SECRET=your_teams_client_secret
TEAMS_TENANT_ID=your_teams_tenant_id

# File Storage
STORAGE_TYPE=local
STORAGE_PATH=/var/mekala/storage
AWS_S3_BUCKET=mekala-storage
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# AI Services
OPENAI_API_KEY=your_openai_api_key
GOOGLE_SPEECH_API_KEY=your_google_speech_api_key
AZURE_COGNITIVE_KEY=your_azure_cognitive_key

# Security
ENCRYPTION_KEY=your-32-character-encryption-key
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Logging
LOG_LEVEL=info
ELASTICSEARCH_URL=http://elasticsearch:9200
KIBANA_PORT=5601

# Application Settings
MAX_FILE_UPLOAD_SIZE=50MB
SESSION_TIMEOUT=3600
GRACE_PERIOD_DAYS=3
